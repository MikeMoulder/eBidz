# ── Rust / Cargo build artifacts ─────────────────────────────────────────────
target/

# ── Solana / program keypairs  (SENSITIVE — NEVER commit) ────────────────────
*-keypair.json
*.keypair.json
ebidz-keypair.json

# ── Backup files ──────────────────────────────────────────────────────────────
*.bak

# ── Windows artefact (created when stdout is redirected to NUL) ───────────────
programs/ebidz/nul

# ── Compiled BPF/SBF program binaries ────────────────────────────────────────
# (target/ covers target/deploy/*.so — these are root-level stray copies)
*.so

# ── Node.js / Next.js ─────────────────────────────────────────────────────────
app/node_modules/
app/.next/
app/out/
app/.env*.local

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.production
.env.staging

# ── Claude AI local config ────────────────────────────────────────────────────
.claude/settings.local.json

# ── IDE / editor ──────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.iml

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
